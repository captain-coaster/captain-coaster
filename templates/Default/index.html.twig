{% extends "base.html.twig" %}

{% import "helper.html.twig" as helper %}

{% set openedSidebar = true %}
{% set hideTitle = true %}

{% set title = 'index.title'|trans %}
{% block title %}{{ 'index.header.title'|trans }}{% endblock %}

{% block header %}
  <meta name="description" content="{{ 'index.description'|trans }}"/>
  <meta property="og:title" content="{{ 'app.name'|trans }}"/>
  <meta property="og:type" content="website"/>
  <meta property="og:url" content="{{ app.request.uri }}"/>
  <meta property="og:image" content="{{ absolute_url(asset('images/logo_big.png')) }}"/>
{% endblock %}

{% block body %}
  <!-- Info alert for non-authenticated users -->
  {% if not is_granted('IS_AUTHENTICATED_REMEMBERED') %}
    <div class="alert alert-info alert-dismissible fade show" role="alert">
      <h6 class="alert-heading font-semibold">{{ 'index.header.title'|trans }}</h6>
      {{ 'index.header.info'|trans({'%link_path%': path('login')})|raw }}
      <button type="button" class="p-2 rounded-lg text-neutral-500 hover:bg-neutral-100 dark:hover:bg-neutral-800" onclick="this.parentElement.remove()" aria-label="Close">
        {{ ux_icon('heroicons:x-mark', {'class': 'w-4 h-4'}) }}
      </button>
    </div>
  {% endif %}

  <!-- Stats row -->
  <div class="grid grid-cols-1 md:grid-cols-12 gap-4 mb-4">
    <div class="col-span-12">
      <div class="bg-white dark:bg-neutral-900 rounded-2xl shadow-sm overflow-hidden">
        <div class="p-6">
          <div class="grid grid-cols-1 md:grid-cols-12 gap-4 text-center">
            <div class="col-3">
              <p class="mb-2">{{ ux_icon('heroicons:star', {'class': 'icon-lg text-success'}) }}</p>
              <h5 class="font-semibold mb-0">
                {{ stats.nb_ratings }}
                {% if stats.nb_new_ratings > 0 %}
                  <span class="badge bg-warning text-dark">+{{ stats.nb_new_ratings }}</span>
                {% endif %}
              </h5>
              <span class="text-neutral-600 dark:text-neutral-400 small">{{ 'index.stats.ratings'|trans }}</span>
            </div>
            <div class="col-3">
              <p class="mb-2">{{ ux_icon('heroicons:megaphone', {'class': 'icon-lg text-success'}) }}</p>
              <h5 class="font-semibold mb-0">
                <a href="{{ path('review_list') }}">{{ stats.nb_reviews }}</a>
              </h5>
              <span class="text-neutral-600 dark:text-neutral-400 small">{{ 'index.stats.reviews'|trans }}</span>
            </div>
            <div class="col-3">
              <p class="mb-2">{{ ux_icon('heroicons:user-group', {'class': 'icon-lg text-warning'}) }}</p>
              <h5 class="font-semibold mb-0">
                <a href="{{ path('user_list') }}">{{ stats.nb_users }}</a>
              </h5>
              <span class="text-neutral-600 dark:text-neutral-400 small">{{ 'index.stats.users'|trans }}</span>
            </div>
            <div class="col-3">
              <p class="mb-2">{{ ux_icon('heroicons:camera', {'class': 'icon-lg text-blue-600 dark:text-blue-400'}) }}</p>
              <h5 class="font-semibold mb-0">{{ stats.nb_images }}</h5>
              <span class="text-neutral-600 dark:text-neutral-400 small">{{ 'index.stats.images'|trans }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
    <div class="md:col-span-6">
      <!-- Featured image card -->
      <div class="bg-white dark:bg-neutral-900 rounded-2xl shadow-sm overflow-hidden mb-4">
        <a href="{{ path('show_coaster', {'id': image.coaster.id, 'slug': image.coaster.slug}) }}" class="relative">
          <img src="{{ pictures_cdn }}/600x336/{{ image.filename }}" class="card-img-top" alt="{{ image.coaster.name }}">
          <div class="absolute bottom-0 start-0 end-0 p-3 bg-gradient-to-t from-black/70 to-transparent">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/20 dark:text-blue-400">{{ image.coaster.name }}</span>
          </div>
        </a>
        <div class="p-6 text-center py-2">
          <p class="text-neutral-600 dark:text-neutral-400 text-sm mb-0">{{ 'image.credit'|trans({'%name%': image.credit}) }}</p>
        </div>
      </div>

      <!-- Latest ratings -->
      <div class="bg-white dark:bg-neutral-900 rounded-2xl shadow-sm overflow-hidden mb-4 border-top border-4 border-primary">
        <div class="px-6 py-4 bg-neutral-50 dark:bg-neutral-800 border-b border-neutral-100 dark:border-neutral-700">
          <h6 class="text-lg font-semibold text-neutral-900 dark:text-white mb-0">{{ 'rating.last'|trans }}</h6>
        </div>
        <div class="p-6">
          <ul class="list-feed">
            {% for ratingItem in ratingFeed %}
              <li>
                <a class="font-bold" href="{{ path('user_show', {'slug': ratingItem.user.slug}) }}">
                  {{ ratingItem.user.displayName }}
                </a>
                {{ 'rating.action'|trans({'%value%': ratingItem.value}) }}
                <a href="{{ path('show_coaster', {'id': ratingItem.coaster.id, 'slug': ratingItem.coaster.slug}) }}">
                  {{ ratingItem.coaster.name }}
                </a>
                <div class="text-neutral-600 dark:text-neutral-400 small">{{ ratingItem.updatedAt|ago }}</div>
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>

    <div class="md:col-span-6">
      <!-- Latest reviews -->
      <div class="bg-white dark:bg-neutral-900 rounded-2xl shadow-sm overflow-hidden mb-4">
        <div class="px-6 py-4 bg-neutral-50 dark:bg-neutral-800 border-b border-neutral-100 dark:border-neutral-700 flex justify-content-between items-center">
          <h6 class="text-lg font-semibold text-neutral-900 dark:text-white mb-0">
            {{ ux_icon('heroicons:chat-bubble-left', {'class': 'icon-sm mr-1'}) }}
            {{ 'review.last'|trans }}
          </h6>
          <a href="{{ path('review_list') }}" class="text-sm">
            {{ 'review.all'|trans }}
            {{ ux_icon('heroicons:arrow-right', {'class': 'icon-xs'}) }}
          </a>
        </div>
        <div class="p-6">
          <ul class="list-none reviews-list">
            {% for review in reviews %}
              <li class="mb-3 pb-3 border-bottom">
                <div class="review-coaster-info mb-2">
                  <h6 class="font-semibold mb-0">
                    <a href="{{ path('show_coaster', {'id': review.coaster.id, 'slug': review.coaster.slug}) }}">
                      {{ review.coaster.name }}
                    </a>
                    <span class="text-neutral-600 dark:text-neutral-400 font-normal">-</span>
                    <a href="{{ path('park_show', {'id': review.coaster.park.id, 'slug': review.coaster.park.slug}) }}" class="text-neutral-600 dark:text-neutral-400">
                      {{ review.coaster.park.name }}
                    </a>
                  </h6>
                </div>
                {% include 'Includes/_review_item.html.twig' with {'review': review, 'displayReviewsInAllLanguages': displayReviewsInAllLanguages} %}
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>

      <!-- Missing images -->
      {% if missingImages|length > 1 %}
        <div class="bg-white dark:bg-neutral-900 rounded-2xl shadow-sm overflow-hidden mb-4 border-top border-4 border-primary">
          <div class="px-6 py-4 bg-neutral-50 dark:bg-neutral-800 border-b border-neutral-100 dark:border-neutral-700">
            <h6 class="text-lg font-semibold text-neutral-900 dark:text-white mb-0">{{ 'index.missingImages'|trans }}</h6>
          </div>
          <div class="p-6">
            <ul class="list-feed">
              {% for rating in missingImages %}
                <li>
                  <a href="{{ path('coaster_images_upload', {'slug': rating.coaster.slug}) }}">
                    {{ rating.coaster.name }} • {{ rating.coaster.park.name }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}

{% block javascripts %}
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js', {scope: '/'}).then(function() {
        console.log('Service Worker Registered');
      }).catch(function(e) {
        console.log('Error during Service Worker registration : ', e);
      });
    }
  </script>
{% endblock %}
