{% extends "base.html.twig" %}

{% set title = 'title'|trans([], 'policy') %}
{% block title %}{{ title }}{% endblock %}

{% block body %}
  <article class="bg-white dark:bg-neutral-900 rounded-2xl overflow-hidden shadow-sm">
    <div class="p-8 prose prose-neutral dark:prose-invert max-w-none">
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-neutral-900 dark:text-white mb-4">
          {{ 'terms.title'|trans([], 'policy') }}
        </h2>
        <div class="text-neutral-700 dark:text-neutral-300">
          {{ 'terms.text'|trans([], 'policy')|raw }}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold text-neutral-900 dark:text-white mb-4">
          {{ 'privacy.title'|trans([], 'policy') }}
        </h2>
        <div class="text-neutral-700 dark:text-neutral-300">
          {{ 'privacy.text'|trans({'%link_href%': path('default_contact')}, 'policy')|raw }}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold text-neutral-900 dark:text-white mb-4">
          {{ 'cookies.title'|trans([], 'policy') }}
        </h2>
        <div class="text-neutral-700 dark:text-neutral-300">
          {{ 'cookies.text'|trans({'%link_href%': path('default_contact')}, 'policy')|raw }}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold text-neutral-900 dark:text-white mb-4">
          {{ 'hosting.title'|trans([], 'policy') }}
        </h2>
        <div class="text-neutral-700 dark:text-neutral-300">
          {{ 'hosting.text'|trans([], 'policy')|raw }}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold text-neutral-900 dark:text-white mb-4">
          {{ 'copyright.title'|trans([], 'policy') }}
        </h2>
        <div class="text-neutral-700 dark:text-neutral-300">
          {{ 'copyright.text'|trans({'%link_href%': path('default_contact')}, 'policy')|raw }}
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-neutral-900 dark:text-white mb-4">
          {{ 'contact.title'|trans([], 'policy') }}
        </h2>
        <div class="text-neutral-700 dark:text-neutral-300">
          {{ 'contact.text'|trans({'%link_href%': path('default_contact')}, 'policy')|raw }}
        </div>
      </section>
    </div>
  </article>
{% endblock %}
