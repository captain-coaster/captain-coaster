<!DOCTYPE html>
<html lang="{{ app.request.get('_locale') }}" data-symfony-ux-translator-locale="{{ app.request.locale }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}{{ 'app.title.default'|trans }}{% endblock %} • {{ 'app.name'|trans }}</title>
  <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('apple-touch-icon.png') }}">
  <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('favicon-32x32.png') }}">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('favicon-16x16.png') }}">
  <link rel="mask-icon" href="{{ asset('safari-pinned-tab.svg') }}" color="#2b5797">
  <link rel="shortcut icon" href="{{ asset('favicon.ico') }}">
  <meta name="apple-mobile-web-app-title" content="{{ 'app.name'|trans }}">
  <meta name="application-name" content="{{ 'app.name'|trans }}">
  <meta name="msapplication-TileColor" content="#2b5797">
  <meta name="theme-color" content="#28343a">
  <link rel="manifest" href="{{ asset('manifest.json') }}">
  {% block header %}{% endblock %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  {{ vite_entry_link_tags('app') }}
  {% block stylesheets %}{% endblock %}
</head>
<body class="bg-neutral-50 dark:bg-neutral-900">
  <!-- Main navbar (fixed top) -->
  {{ include('navbar.html.twig') }}

  <!-- Page layout -->
  <div class="flex min-h-screen">
    <!-- Main sidebar (desktop: visible, mobile: offcanvas) -->
    {{ include('sidebar.html.twig') }}

    <!-- Main content -->
    <main id="main-content" class="flex-1 md:ml-64 pt-16 pb-20 md:pb-0" role="main" aria-label="{{ 'main.content.label'|trans({}, 'navigation') }}">
      {% block wide_body %}
        <!-- Page header -->
        {{ include('page_header.html.twig', {
          'title': title|default('Bienvenue !'),
          'subTitle': subTitle|default(null),
          'secondaryTitle': secondaryTitle|default(null),
          'pageHasFilters': pageHasFilters|default(false)
        }) }}

        <!-- Content area -->
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
          {{ include('flashes.html.twig') }}
          <div id="notifications" data-controller="notification" data-notification-target="container"></div>

          {% block body %}{% endblock %}
        </div>

        <!-- Footer -->
        {{ include('footer.html.twig') }}
      {% endblock %}
    </main>

    <!-- Secondary sidebar (filters) - must be after main-content for flex order -->
    {% block secondary_sidebar %}{% endblock %}
  </div>

  <!-- Core JS files -->
  {{ vite_entry_script_tags('app') }}

  <script src="{{ asset('bundles/fosjsrouting/js/router.js') }}"></script>
  <script src="{{ path('fos_js_routing_js', { callback: 'fos.Router.setData' }) }}"></script>

  <!-- Page-specific entries -->
  {% block javascripts %}{% endblock %}
  {% if app.environment != 'dev' %}
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-M2S96P7YEW"></script>
  <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-M2S96P7YEW');
  </script>
  {% endif %}
</body>
</html>
