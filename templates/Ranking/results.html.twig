{# Ranking Results - Mobile-first leaderboard #}
{% import "macros/ui.html.twig" as ui %}

<div class="grid grid-cols-2 gap-3">
  {% for coaster in coasters %}
<article class="bg-white dark:bg-neutral-900 rounded-xl shadow-sm border border-neutral-100 dark:border-neutral-800 overflow-hidden hover:shadow-md transition-all duration-200">

    {# Image + rang fondu + nom sur gradient #}
    <div class="relative overflow-hidden" style="height: 140px;">

        {% if coaster.mainImage is not null %}
        <a href="{{ path('show_coaster', {'id': coaster.id, 'slug': coaster.slug}) }}">
            <img src="{{ pictures_cdn }}/600x336/{{ coaster.mainImage.filename }}"
                class="absolute inset-0 w-full h-full object-cover brightness-60"
                alt="{{ coaster.name }}"
                loading="lazy">
        </a>
        {% else %}
        <div class="absolute inset-0 bg-neutral-800"></div>
        {% endif %}

        {# Gradient bas + rang lisible + score #}
<<div class="absolute bottom-0 left-0 right-0 px-3 py-2 bg-gradient-to-t from-black/80 via-black/40 to-transparent flex items-baseline justify-between">
    
    {# Groupe rang + variation #}
    <div class="flex items-baseline gap-1.5">
        <span class="text-lg font-black leading-none px-2 py-0.5 rounded-md inline-flex items-baseline gap-1.5
    {% if coaster.rank == 1 %}bg-yellow-400  text-yellow-900 
    {% elseif coaster.rank == 2 %}bg-slate-300  text-slate-800 
    {% elseif coaster.rank == 3 %}bg-amber-500  text-amber-950 
    {% else %}bg-white/80 dark:bg-black/60 text-slate-800/80 dark:text-white/80{% endif %}">
    #{{ coaster.rank }}
    {% if coaster.previousRank is empty %}
    <span title="{{ 'coaster_ranking.new'|trans }}">
        {{ ux_icon('tabler:sparkles', {'class': 'w-3 h-3', 'aria-label': 'coaster_ranking.new'|trans}) }}
    </span>
    {% elseif coaster.previousRank < coaster.rank %}
    <span class="flex items-center gap-0.5 text-xs font-bold text-red-600 dark:text-red-700">
        {{ ux_icon('tabler:arrow-down', {'class': 'w-3 h-3', 'aria-hidden': 'true'}) }}{{ (coaster.rank - coaster.previousRank)|abs }}
    </span>
    {% elseif coaster.previousRank > coaster.rank %}
    <span class="flex items-center gap-0.5 text-xs font-bold text-green-600 dark:text-green-700">
        {{ ux_icon('tabler:arrow-up', {'class': 'w-3 h-3', 'aria-hidden': 'true'}) }}{{ (coaster.rank - coaster.previousRank)|abs }}
    </span>
    {% else %}
    <span class="text-xs opacity-50">—</span>
    {% endif %}
</span>
    </div>

    {# Score #}
    {% if coaster.score is not null %}
    <span class="text-xs font-semibold text-white/90 drop-shadow-[0_1px_2px_rgba(0,0,0,0.8)]">
        {{ coaster.score|number_format(1) }}%
    </span>
    {% endif %}

</div>

    </div>

    {# Infos #}
    <div class="p-2 flex flex-col gap-0.5">
        <h2 class="font-semibold text-base text-neutral-900 dark:text-white truncate">
    <a href="{{ path('show_coaster', {'id': coaster.id, 'slug': coaster.slug}) }}"
       class="hover:text-cc-blue-600 dark:hover:text-cc-blue-400 transition-colors">
        {{ coaster.name }}
    </a>
</h2>
        <div class="text-xs text-neutral-500 dark:text-neutral-400 truncate">
            {% if coaster.manufacturer %}
            <a href="{{ path('ranking_index', {'filters[manufacturer]': coaster.manufacturer.id}) }}"
               class="hover:text-cc-blue-600 dark:hover:text-cc-blue-400 transition-colors">
                {{ coaster.manufacturer.name }}
            </a>
            <span class="text-neutral-300 dark:text-neutral-600"> • </span>
            {% endif %}
            <a href="{{ path('park_show', {'id': coaster.park.id, 'slug': coaster.park.slug}) }}"
               class="hover:text-cc-blue-600 dark:hover:text-cc-blue-400 transition-colors">
                {{ coaster.park.name }}
            </a>
        </div>
    </div>

</article>
  {% endfor %}
</div>
{{ knp_pagination_render(coasters) }}
