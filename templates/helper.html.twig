            {{ ux_icon('heroicons-solid:star', {'class': 'icon-sm'}) }}
        {%- elseif rating == 0.5 -%}
            {{ ux_icon('half-star', {'class': 'icon-sm'}) }}
        {%- endif -%}
    </span>
{% endmacro %}
