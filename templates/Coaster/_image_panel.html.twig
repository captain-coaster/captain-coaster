<section class="bg-neutral-50 dark:bg-neutral-900 rounded-2xl overflow-hidden shadow-sm">
    <div class="px-6 py-4 bg-neutral-50 dark:bg-neutral-800 border-b border-neutral-100 dark:border-neutral-700 flex justify-between items-center">
        <h2 class="text-lg font-semibold text-neutral-900 dark:text-white flex items-center gap-2">
            {{ ux_icon('tabler:photo', {'class': 'w-5 h-5 text-cc-blue-500', 'aria-hidden': 'true'}) }}
            {{ 'coaster.photos.title'|trans }}
            {% if coaster.images|length > 0 %}
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-cc-blue-100 text-cc-blue-800 dark:bg-cc-blue-900/20 dark:text-cc-blue-400">
                    {{ coaster.images|length }}
                </span>
            {% endif %}
        </h2>
        <a href="{{ path('coaster_images_upload', {'slug': coaster.slug}) }}" 
           class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-cc-blue-600 dark:hover:text-cc-blue-400 transition-colors duration-200">
            {{ 'coaster.photos.button'|trans }}
        </a>
    </div>
    
    {% if coaster.images|length > 0 %}
        <div class="p-6" 
             data-controller="gallery" 
             data-gallery-name-value="coaster-images"
             data-gallery="coaster-images">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                {% for image in coaster.images|slice(0, number) %}
                    <div class="group relative rounded-xl overflow-hidden"
                         data-controller="image-like"
                         data-image-like-image-id-value="{{ image.id }}"
                         data-image-like-locale-value="{{ app.request.locale }}"
                         data-image-like-liked-value="{% if image.id in userLikes %}true{% else %}false{% endif %}">
                        <a href="{{ pictures_cdn }}/1440x1440/{{ image.filename }}" 
                           data-gallery-target="link"
                           data-credit="{{ image.credit|default('') }}"
                           class="block">
                            <div class="aspect-4/3 overflow-hidden">
                                <img src="{{ pictures_cdn }}/280x210/{{ image.filename }}"
                                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                                     alt="{{ coaster.name }}"
                                     loading="lazy">
                            </div>
                        </a>
                        {# Heart — top-right, visible on hover (desktop) or always (mobile) #}
                        <div class="absolute top-2 right-2 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-200">
                            <button type="button"
                                    data-action="click->image-like#toggle"
                                    data-image-like-target="icon"
                                    class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-black/40 backdrop-blur-sm text-white/90 hover:text-red-400 hover:bg-black/60 transition-all duration-200 focus:outline-none">
                            </button>
                        </div>
                        {# Credit + likes — bottom, visible on hover (desktop) or always (mobile) #}
                        <div class="absolute inset-x-0 bottom-0 bg-linear-to-t from-black/60 to-transparent px-3 pt-8 pb-2 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-200">
                            <div class="flex items-center justify-between">
                                {% if image.credit %}
                                    <span class="text-xs font-medium text-white/90 truncate mr-2">{{ image.credit }}</span>
                                {% else %}
                                    <span></span>
                                {% endif %}
                                <div class="flex items-center gap-1 shrink-0">
                                    {{ ux_icon('tabler:heart-filled', {'class': 'w-3 h-3 text-red-400', 'aria-hidden': 'true'}) }}
                                    <span data-image-like-target="counter" class="text-xs font-medium text-white/90">{{ image.likeCounter }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
        {% if number < coaster.images|length %}
            <div class="px-6 py-4 bg-neutral-50 dark:bg-neutral-800 border-t border-neutral-100 dark:border-neutral-700 text-center">
                <button id="show-all" 
                        class="text-cc-blue-600 hover:text-cc-blue-700 dark:text-cc-blue-400 dark:hover:text-cc-blue-300 font-medium transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-cc-blue-500 focus:ring-offset-2 rounded px-4 py-2">
                    {{ 'coaster.photos.all'|trans }}
                </button>
            </div>
        {% endif %}
    {% else %}
        <div class="px-6 py-12 text-center">
            <div class="w-16 h-16 bg-neutral-100 dark:bg-neutral-800 rounded-2xl flex items-center justify-center mx-auto mb-4">
                {{ ux_icon('tabler:photo', {'class': 'w-8 h-8 text-neutral-400 dark:text-neutral-500', 'aria-hidden': 'true'}) }}
            </div>
            <p class="text-neutral-600 dark:text-neutral-400 mb-4">{{ 'coaster.photos.empty'|trans }}</p>
            <a href="{{ path('coaster_images_upload', {'slug': coaster.slug}) }}" 
               class="inline-flex items-center px-4 py-2 bg-cc-blue-600 hover:bg-cc-blue-700 text-white text-sm font-medium rounded-lg transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-cc-blue-500 focus:ring-offset-2">
                {{ 'coaster.photos.button'|trans }}
            </a>
        </div>
    {% endif %}
</section>
