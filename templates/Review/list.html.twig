{% extends "layouts/base.html.twig" %}

{% import "macros/ui.html.twig" as ui %}

{% set title = 'review_list.title'|trans %}
{% block title %}{{ title }}{% endblock %}

{% block body %}
  {# Hero Section #}
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-neutral-900 dark:text-white mb-1">
      {{ ux_icon('tabler:message-circle', {'class': 'w-7 h-7 inline-block text-cc-blue-500 mr-2', 'aria-hidden': 'true'}) }}
      {{ 'review.title'|trans }}
    </h1>
    <p class="text-neutral-600 dark:text-neutral-400 text-sm">
      {{ 'review.share'|trans }}
    </p>
  </div>

  {% if reviews.getTotalItemCount() > 0 %}
    {# Reviews Feed #}
    <div class="space-y-4">
      {% for review in reviews %}
        {% include 'components/review_card.html.twig' with {
          review: review,
          variant: 'full',
          displayReviewsInAllLanguages: true,
          showCoaster: true,
          showActions: true,
          maxReviewLength: 300
        } only %}
      {% endfor %}
    </div>

    <div class="mt-6">
      {{ knp_pagination_render(reviews) }}
    </div>
  {% else %}
    {% include 'components/empty_state.html.twig' with {
      icon: 'tabler:message-circle-off',
      title: 'review_list.no_review'|trans,
      description: 'review.share'|trans
    } %}
  {% endif %}
{% endblock %}
